FMP_API_KEY=
OPENCODE_GO_API_KEY=

# Optional: X posting. X_POST_ENABLED=false renders images without posting.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_POST_ENABLED=false
X_INCLUDE_TITLE=false

# App auth
AUTH_PIN=123456
SECRET_PIN=
URA_PIN=
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Recognition Gap EP runtime
# 0/all means keep every detected candidate and render every row into images.
RECOGNITION_GAP_TOP_N=0
RECOGNITION_GAP_MIN_CLOSE=1.5
RECOGNITION_GAP_MIN_DOLLAR_VOLUME20=1000000
RECOGNITION_GAP_PROFILE_FETCH_LIMIT=350
RECOGNITION_GAP_RENDER_X_IMAGES=true

# Optional reporting routes. Trading/order buttons are not implemented.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Optional legacy routes only
OPENAI_API_KEY=
FRED_API_KEY=

# Optional only if Webull read/reporting is re-enabled later. Trading remains disabled.
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_ACCOUNT_ID=
